# Copie para .env e troque todos os valores antes de iniciar os runtimes de agentes.
POSTGRES_DB=agentspool
POSTGRES_USER=agentspool
POSTGRES_PASSWORD=troque-esta-senha
FRONTEND_PORT=15173
BACKEND_PORT=18080

# Usada pelo Hermes/OpenClaw como provedor de modelos. Pode ficar vazia para configurar outro provedor no onboarding.
OPENROUTER_API_KEY=

# Segredos compartilhados apenas entre o backend e os gateways na rede Docker.
HERMES_API_SERVER_KEY=troque-esta-chave-hermes
OPENCLAW_GATEWAY_TOKEN=troque-este-token-openclaw
